generator client {
  provider = "prisma-client"
  output   = "./client"
}

datasource db {
  provider = "sqlite"
}

/// Coincide con `script.sql`: CHECK en `Account.type`.
enum AccountType {
  EFECTIVO
  TARJETA
}

/// Coincide con `script.sql`: CHECK en `transactions.type`.
enum TransactionType {
  INGRESO
  GASTO
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  accounts      Account[]
  categories    Category[]
  transactions  Transaction[]
  subscriptions Subscription[]
  budgets       Budget[]
}

model Account {
  id             Int         @id @default(autoincrement())
  userId         Int         @map("user_id")
  name           String
  type           AccountType
  initialBalance Float       @default(0) @map("initial_balance")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  subscriptions Subscription[]

  @@index([userId])
}

model Category {
  id           Int     @id @default(autoincrement())
  userId       Int     @map("user_id")
  name         String
  color        String?
  monthlyLimit Float?  @map("monthly_limit")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  subscriptions Subscription[]
}

model Transaction {
  id         Int             @id @default(autoincrement())
  userId     Int             @map("user_id")
  accountId  Int             @map("account_id")
  categoryId Int             @map("category_id")
  budgetId   Int?            @map("budget_id")
  type       TransactionType
  amount     Float
  occurredAt DateTime        @map("occurred_at")
  note       String?

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  Account       @relation(fields: [accountId], references: [id], onDelete: Restrict)
  category Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  budget   Budget? @relation(fields: [budgetId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([budgetId])
  @@map("transactions")
}

model Budget {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  amount    Float
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@map("budget")
}

model Subscription {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  accountId       Int      @map("account_id")
  categoryId      Int      @map("category_id")
  name            String
  amount          Float
  nextBillingDate DateTime @map("next_billing_date")
  active          Int      @default(1)

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account  Account  @relation(fields: [accountId], references: [id], onDelete: Restrict)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([nextBillingDate])
  @@map("subscription")
}
